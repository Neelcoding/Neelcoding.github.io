# Copy this file to .env.local for local development, and add the same
# values to your Vercel project's Environment Variables for production.
# See README.md for where to find each of these.

# ---- Supabase ----
# Project Settings -> API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SECRET. Only used server-side (API routes, server
# actions). Never prefix this with NEXT_PUBLIC_ and never send it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Admin access ----
# Comma-separated list of the email address(es) allowed into /admin.
# Must match the email of a real user you create in Supabase Auth.
ADMIN_EMAILS=you@example.com

# ---- Stripe ----
# Developers -> API keys in your Stripe dashboard. Use test keys (sk_test_/
# pk_test_) until you're ready to accept real payments.
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ---- Site ----
# Used to build Stripe redirect URLs. Use http://localhost:3000 locally and
# your real domain (e.g. https://buzzsscents.com) in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
